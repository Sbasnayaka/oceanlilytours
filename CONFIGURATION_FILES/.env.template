# ============================================
# SITE CONFIGURATION
# ============================================
ADMIN_EMAIL=admin@oceanlilly.com
ADMIN_NAME="Ocean Lilly Tours Admin"
SITE_NAME="Ocean Lilly Tours"
SITE_DESCRIPTION="Premium Sri Lanka Tours and Adventures"

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
UPLOAD_PATH=/uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf
ADMIN_UPLOADS_PATH=/admin-uploads

# ============================================
# SECURITY SETTINGS
# ============================================
CORS_ORIGINS=*
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_SECURE_COOKIES=true

# ============================================
# API SETTINGS
# ============================================
API_VERSION=1.0
API_RATE_LIMIT=100
API_TIMEOUT=30

