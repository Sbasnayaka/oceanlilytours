<IfModule mod_rewrite.c>
    RewriteEngine On

    # If your host does NOT allow setting document root to /backend/public,
    # this forwards all /backend/* requests into /backend/public/*.
    # Then Laravel's public/.htaccess routes to public/index.php.
    RewriteCond %{REQUEST_URI} !/public/ [NC]
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

